# ============================================================
# py_free_image_moderation - complete .env example
# This file is also loaded as fallback defaults when no .env/.env.txt exists.
# Copy this file to .env and edit values there for your environment.
# ============================================================

# ---------- Debug / dotenv ----------
# Logger level (e.g. DEBUG, INFO, WARNING, ERROR)
MODIMG_LOG_LEVEL=INFO
# 1 = modimg debug mode
MODIMG_DEBUG=0
# 1 = debug output for dotenv loading
DEBUG=0
# 1 = override existing shell env vars with dotenv values
DOTENV_OVERRIDE=0
# TensorFlow/C++ log level: 2 hides INFO+WARNING noise (keeps errors)
TF_CPP_MIN_LOG_LEVEL=2

# ---------- Parallelization ----------
# 1 = run engines in parallel
MODIMG_PARALLEL_ENGINES=0
# Worker count when parallelization is enabled
MODIMG_PARALLEL_WORKERS=4

# ---------- CLI / Reporting ----------
# Number of sampled frames for animated images (GIF/WebP animation)
SAMPLE_FRAMES=12
# 1 = print all engine scores
SCORE_VERBOSE=0
# Max score keys shown for non-Sightengine outputs
SCORE_MAX_KEYS=8
# Sightengine score output mode: compact | full | keys
SIGHTENGINE_SCORE_MODE=compact
# Used only when SIGHTENGINE_SCORE_MODE=keys (comma-separated)
SIGHTENGINE_SCORE_KEYS=
# In compact mode, append strongest additional signals (0 = off)
SIGHTENGINE_EXTRA_TOPK=0

# ---------- API execution policy ----------
# always: run APIs after local engines
# on_review: run APIs only if local stage returns REVIEW
# never: never run API engines
API_POLICY=always

# ---------- pHash lists / behavior ----------
# Optional path to pHash allowlist
PHASH_ALLOWLIST=data/phash_allowlist.txt
# Optional path to pHash blocklist
PHASH_BLOCKLIST=data/phash_blocklist.txt

# 1 = disable pHash allowlist engine
PHASH_ALLOW_DISABLE=0
# 1 = disable pHash blocklist engine
PHASH_BLOCK_DISABLE=0

# 0 means exact pHash match is required on allowlist (strict default)
PHASH_ALLOW_MAX_DISTANCE=0
# 6 is the current tolerant default for blocklist matching
PHASH_BLOCK_MAX_DISTANCE=6
# Preferred variables are PHASH_ALLOW_MAX_DISTANCE and PHASH_BLOCK_MAX_DISTANCE.
# Legacy aliases are still recognized by current code:
# PHASH_ALLOW_MAXDIST=
# PHASH_BLOCK_MAXDIST=
# PHASH_MAXDIST=

# 1 = pHash hit short-circuits (allowlist => OK, blocklist => BLOCK)
SHORT_CIRCUIT_PHASH=1

# ---------- pHash auto-learning ----------
# Master switch (recommended)
PHASH_AUTO_LEARN_ENABLE=1
# Legacy back-compat switch (still read)
PHASH_AUTO_APPEND=0
# 1 = append pHash to allowlist after OK verdict
PHASH_AUTO_ALLOW_APPEND=1
# 1 = append pHash to blocklist after BLOCK verdict
PHASH_AUTO_BLOCK_APPEND=1
# Generic auto-learn label fallback
PHASH_AUTO_LABEL=ok
# Specific labels
PHASH_AUTO_ALLOW_LABEL=ok
PHASH_AUTO_BLOCK_LABEL=not_ok
# 1 = for GIFs learn first + last sampled frame (instead of first only)
PHASH_GIF_LEARN_FIRST_LAST=1

# ---------- OCR ----------
# 1 = enable OCR engine
OCR_ENABLE=0
# OCR language (e.g. eng, deu, deu+eng)
OCR_LANG=eng
# Max sampled frames OCR checks on animated images/GIFs
OCR_MAX_FRAMES=2
# Minimum text length to keep OCR signal
OCR_MIN_LEN=3
# Optional explicit path to tesseract binary
TESSERACT_CMD=

# ---------- OpenNSFW2 ----------
# 1 = disable OpenNSFW2 engine
OPENNSFW2_DISABLE=0

# ---------- NudeNet ----------
# 1 = disable NudeNet engine
NUDENET_DISABLE=0

# ---------- YOLO weapons detection ----------
# Backend (currently implemented: ultralytics)
YOLO_BACKEND=ultralytics
# Optional model path/weights
YOLO_WORLD_MODEL=
YOLO_WEAPON_MODEL=
YOLO_WEAPONS_WEIGHTS=
# Inference parameters
YOLO_CONF=0.25
YOLO_IOU=0.45
# Lower image size is faster but usually less accurate
YOLO_IMGSZ=640
# Maximum detections kept per frame/image
YOLO_MAX_DET=50
# Max sampled frames YOLO checks on animated images/GIFs
YOLO_MAX_FRAMES=2
YOLO_DEVICE=

# Decision thresholds (verdict.py)
YOLO_FIREARM_THRESH=0.35
YOLO_FIREARM_TOY_THRESH=0.25
ALLOW_TOY_GUN=0
YOLO_DANGEROUS_KNIFE_THRESH=0.35
YOLO_KNIFE_THRESH=0.65
YOLO_KNIFE_BLOCK_ALL=0

# ---------- OpenAI moderation ----------
# 1 = disable OpenAI engine
OPENAI_DISABLE=1
OPENAI_API_KEY=
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_REQUEST_TIMEOUT_SEC=20
OPENAI_MIN_INTERVAL_SEC=1.0
OPENAI_MAX_RETRIES=6
OPENAI_BACKOFF_BASE_SEC=1.0
OPENAI_BACKOFF_MAX_SEC=10
OPENAI_MAX_TOTAL_SLEEP_SEC=30
# For HTTP 429: retry | skip
OPENAI_429_POLICY=retry
OPENAI_MAX_429_RETRIES=3
# Local cache
OPENAI_CACHE_ENABLE=1
OPENAI_CACHE_PATH=.cache/openai_moderation_cache.json
OPENAI_CACHE_MAX_ITEMS=2000

# ---------- Sightengine ----------
# 1 = disable Sightengine engine even if credentials are set
SIGHTENGINE_DISABLE=0
SIGHTENGINE_USER=
SIGHTENGINE_SECRET=
SIGHTENGINE_MODELS=nudity-2.1,weapon,violence,gore-2.0,offensive-2.0

# Decision thresholds (verdict.py)
SE_FIREARM_THRESH=0.35
SE_BLOCK_ANY_FIREARM=0
SE_VIOLENCE_THRESH=0.30
SE_GORE_THRESH=0.20
SE_OFFENSIVE_THRESH=0.50
SE_KNIFE_THRESH=0.65
SE_KNIFE_BLOCK_ALL=0
SE_KNIFE_CONTEXT_THRESH=0.25

# ---------- Global verdict logic ----------
# Comma-separated engine names/aliases treated as "core"
CORE_ENGINES=
# Error policy for core engine failures: ignore | review | block
ENGINE_ERROR_POLICY=review
# Fallback when no engine ran successfully: ok | review | block
NO_CHECKS_POLICY=review
# Final thresholds
FINAL_BLOCK_THRESHOLD=0.85
FINAL_REVIEW_THRESHOLD=0.40

# ---------- Suggested faster local profile ----------
# Copy these into your real .env for faster CPU-only/local scans:
# SAMPLE_FRAMES=4
# OCR_ENABLE=0
# OPENAI_DISABLE=1
# SIGHTENGINE_DISABLE=1
# API_POLICY=never
# YOLO_IMGSZ=416
# YOLO_MAX_DET=20
# YOLO_MAX_FRAMES=1
# PHASH_ALLOW_MAX_DISTANCE=0
# PHASH_BLOCK_MAX_DISTANCE=0
